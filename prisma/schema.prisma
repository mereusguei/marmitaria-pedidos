generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id          Int      @id @default(autoincrement())
  customer    String
  phone       String?
  items       String
  total       Float
  payment     String
  address     String?
  locationUrl String?
  notes       String?
  status      String   @default("novo")
  createdAt   DateTime @default(now())
}